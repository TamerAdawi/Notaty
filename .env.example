# Copy this file to .env.local and fill in your values.
# Supabase dashboard → Project Settings → API
# Without these, Notaty runs in offline demo mode (localStorage, this device only).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push public key (run: npx web-push generate-vapid-keys). Public — safe in the client.
# The matching PRIVATE key goes only in the server env (Vercel) as VAPID_PRIVATE_KEY.
VITE_VAPID_PUBLIC_KEY=
